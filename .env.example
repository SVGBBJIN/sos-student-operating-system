# ─── Server-side secrets (never expose to the browser) ───────────────────────
# Set these in Vercel project settings or via `supabase secrets set`

# Required: Groq API key. Primary chat provider (gpt-oss-20b for flash, gpt-oss-120b
# for pro), vision (llama-4-scout for image chat), and voice (whisper-large-v3-turbo).
GROQ_API_KEY=your_groq_api_key_here

# Required: Google Gemini API key. Used for embeddings (gemini-embedding-002) and
# as the cross-provider fallback when Groq is unavailable (gemini-3-flash for flash
# tier, gemini-2.5-pro for pro tier, planning pipeline thinkingBudget).
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: AI_PROVIDER_OVERRIDE=gemini  forces all routing back to Gemini (rollback
# lever). Toggle without redeploying to disable Groq globally.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ─── LMS submission sync (api/lms-* + supabase/functions/sync-submissions) ───
# Google Classroom OAuth client. Code exchange + refresh happen server-side so
# only the public client id is exposed to the browser; the secret stays here.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# pg_cron schedules the sync orchestrator every 10 minutes. Set these once per
# deployment with `alter database postgres set app.sync_url = '...';` — they
# intentionally are NOT read from this file (secrets stay in the database).
# app.sync_url     = https://<project>.functions.supabase.co/sync-submissions
# app.service_role = <service-role JWT used in the cron Authorization header>

# ─── Client-side variables (VITE_ prefix = bundled into browser code) ─────────
# These are safe to expose; do NOT put API keys with broad permissions here.

# GNews — optional, 100 req/day on free tier.
# Without this, the GET_NEWS data handler returns a graceful fallback message.
VITE_GNEWS_TOKEN=your_gnews_token_here

# Google OAuth public client id used by the LMS setup popup. Public — safe to
# expose; falls back to a built-in default if unset.
VITE_GOOGLE_CLIENT_ID=
